{
  "$schema": "./schema/testing.schema.json",
  "version": 1,
  "layers": [
    {
      "layer": "Backend unit/integration",
      "command": "cd src-tauri && cargo test",
      "notes": "Full TDD — write a failing test first.",
      "when_required": "backend change"
    },
    {
      "layer": "Single test",
      "command": "cd src-tauri && cargo test test_name -- --nocapture",
      "notes": "Scoped iteration.",
      "when_required": "iteration"
    },
    {
      "layer": "Frontend lint",
      "command": "npm run lint",
      "notes": "No unit-test framework; lint + build are the gates.",
      "when_required": "frontend change"
    },
    {
      "layer": "Frontend build",
      "command": "npm run build",
      "notes": "Catches type errors missed by lint.",
      "when_required": "frontend change"
    },
    {
      "layer": "Precision eval",
      "command": "pwsh scripts/eval/eval-edit-quality.ps1",
      "notes": "Fixture-based timing/duration parity.",
      "when_required": "word ops / time mapping / export"
    },
    {
      "layer": "Boundary eval",
      "command": "pwsh scripts/eval/eval-audio-boundary.ps1",
      "notes": "Splice seam quality at sample resolution.",
      "when_required": "editor / waveform / splice / export audio"
    },
    {
      "layer": "i18n parity",
      "command": "bun scripts/check-translations.ts",
      "notes": "All 20 locales in sync.",
      "when_required": "any i18next key change"
    },
    {
      "layer": "E2E",
      "command": "npx playwright test",
      "notes": "tests/app.spec.ts, tests/exportPipeline.spec.ts, etc.",
      "when_required": "user-visible flow change"
    },
    {
      "layer": "Live-app",
      "command": "pwsh scripts/launch-toaster-monitored.ps1 -ObservationSeconds 300",
      "notes": "Required for audio/caption/timeline fixes.",
      "when_required": "audio / caption / timeline / export"
    }
  ]
}
