{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Toaster Quick Rules",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "verb", "scope", "rule"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "verb": { "enum": ["ALWAYS", "PREFER", "AVOID", "NEVER", "FORBIDDEN"] },
          "scope": { "enum": ["root", "rust", "ts", "ui", "i18n", "hygiene", "verification"] },
          "rule": { "type": "string", "minLength": 10, "maxLength": 400 },
          "rationale": { "type": "string" },
          "see": { "type": "array", "items": { "type": "string" } },
          "critical": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
