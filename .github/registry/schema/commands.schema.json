{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Toaster Commands Registry",
  "type": "object",
  "required": ["version", "commands"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tier", "purpose", "command"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "tier": { "enum": ["fast", "full", "live"] },
          "shell": { "enum": ["bash", "pwsh", "any"] },
          "cwd": { "type": "string" },
          "purpose": { "type": "string" },
          "command": { "type": "string" },
          "duration": { "type": "string" },
          "when": { "type": "string" }
        }
      }
    }
  }
}
