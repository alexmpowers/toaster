{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Toaster Testing Matrix",
  "type": "object",
  "required": ["version", "layers"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["layer", "command", "when_required"],
        "additionalProperties": false,
        "properties": {
          "layer": { "type": "string" },
          "command": { "type": "string" },
          "notes": { "type": "string" },
          "when_required": { "type": "string" }
        }
      }
    }
  }
}
