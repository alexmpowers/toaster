{
  "$schema": "./schema/verification.schema.json",
  "version": 1,
  "gates": [
    {
      "id": "cargo-test-backend",
      "when": "backend-touched",
      "command": "cd src-tauri && cargo test",
      "evidence": "Test output showing pass count and no failures."
    },
    {
      "id": "cargo-clippy-backend",
      "when": "backend-touched",
      "command": "cd src-tauri && cargo clippy",
      "evidence": "Clippy output with no warnings in toaster crate."
    },
    {
      "id": "npm-lint-frontend",
      "when": "frontend-touched",
      "command": "npm run lint",
      "evidence": "ESLint output with no errors."
    },
    {
      "id": "npm-build-frontend",
      "when": "frontend-touched",
      "command": "npm run build",
      "evidence": "Vite build output showing successful compile (catches type errors lint misses)."
    },
    {
      "id": "i18n-parity",
      "when": "i18n-touched",
      "command": "bun scripts/check-translations.ts",
      "evidence": "Output showing all 20 locales complete."
    },
    {
      "id": "precision-eval",
      "when": "audio-timeline-export",
      "command": "pwsh scripts/eval/eval-edit-quality.ps1",
      "evidence": "Eval pass/fail JSON + fixture assertions."
    },
    {
      "id": "boundary-eval",
      "when": "audio-timeline-export",
      "command": "pwsh scripts/eval/eval-audio-boundary.ps1",
      "evidence": "Seam-level metrics (xcorr, z-score, preview↔export parity)."
    },
    {
      "id": "live-app-check",
      "when": "ui-playback",
      "command": "pwsh scripts/launch-toaster-monitored.ps1 -ObservationSeconds 300",
      "evidence": "Narrated observed behavior on the exact failing input driven through the live app."
    }
  ]
}
