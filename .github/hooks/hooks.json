{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./session-start.sh",
        "powershell": ".\\session-start.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./session-end.sh",
        "powershell": ".\\session-end.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./log-prompt.sh",
        "powershell": ".\\log-prompt.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./pretool-policy.sh",
        "powershell": ".\\pretool-policy.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./posttool-reminders.sh",
        "powershell": ".\\posttool-reminders.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
