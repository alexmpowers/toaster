{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toaster",
  "version": "0.1.3",
  "identifier": "com.toaster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' asset: https://tauri.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' asset: https://tauri.localhost; style-src 'self' 'unsafe-inline' asset: https://tauri.localhost; img-src 'self' asset: https: blob: data:; media-src 'self' asset: blob: tauri: https://asset.localhost; font-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost tauri: asset: https: http://localhost:*; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "appimage", "deb", "rpm"],
    "resources": ["resources/**/*", "assets/fonts/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": ["libgtk-layer-shell0"]
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCOEI0RUZCNjE3QzA1ODMKUldTREJYeGgrMDZMUzRIMUdqWmJMOGNYOXU1RmxjTHh6RjBGdUVkcEhlVTh0N1FIRzdLOG5QS3MK",
      "endpoints": [
        "https://github.com/alexmpowers/toaster/releases/latest/download/latest.json"
      ]
    }
  }
}
